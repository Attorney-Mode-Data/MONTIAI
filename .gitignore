# ==========================================
# .gitignore for MONTIAI (Attorney-Mode-Data)
# ==========================================

# 1. Environment Variables & Secrets
# NEVER commit credentials or API keys
.env
.env.local
.env.*
secrets.json
credentials/

# 2. Python Artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# 3. Virtual Environments
venv/
.venv/
env/
.env_dir/
ENV/
env.bak/
venv.bak/

# 4. Data & Document Directories
# Ignore extracted data, raw documents, and logs like the DSS files
/data/
/raw_data/
/processed_data/
/assets/
*.pdf
*.csv
*.tsv
*.xlsx
*.doc
*.docx
*.jsonl
/tmp/

# 5. Machine Learning & AI Models
# Ignore large model weights and checkpoints
*.pt
*.pth
*.h5
*.hdf5
*.keras
*.onnx
*.safetensors
*.pkl
*.pickle
/models/
/checkpoints/

# 6. Jupyter Notebooks
.ipynb_checkpoints

# 7. Logs and Databases
*.log
*.sqlite
*.sqlite3
/logs/
DSS_Collection_Log.pdf

# 8. OS Generated Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# 9. IDEs and Editors
.vscode/
.idea/
*.swp
*.swo
.project
.settings/
